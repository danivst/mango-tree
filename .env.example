# --- Server Configuration ---
# Default: 3000
PORT=3000

# MongoDB Connection String (Required)
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/mangotree
MONGO_URI=

# Secret key for JWT authentication (Required)
JWT_SECRET=

# --- URLs & CORS ---
# The URL where your frontend is running (e.g., http://localhost:5173)
CLIENT_URL=http://localhost:5173

# The URL where your backend API is running (e.g., http://localhost:3000)
BASE_API_URL=http://localhost:3000

# Required by Vite (Frontend). Set this to the same value as BASE_API_URL.
VITE_BASE_API_URL=http://localhost:3000

# --- External APIs ---
# DeepL API Key for translations (Required)
DEEPL_API_KEY=

# Google Gemini API Key (Required)
GEMINI_API_KEY=

# Default Gemini Model. Default: gemini-2.5-flash-lite
GEMINI_MODEL_DEFAULT=gemini-2.5-flash-lite

# --- Email Service (Resend) ---
# Optional: If missing, email functionality will be disabled.
RESEND_API_KEY=

# The email address to send from. 
# Default: support@mangotreeofficial.com
# NOTE: If using your own Resend key, this must be a verified sender/domain.
RESEND_FROM_EMAIL=support@mangotreeofficial.com